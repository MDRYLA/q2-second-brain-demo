# Second Brain — example env vars
# Skopiuj do .env.local i wypełnij prawdziwymi wartościami
# .env.local JEST w .gitignore — nigdy nie commituj kluczy

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Faza 7 hardening: canonical app URL dla magic link (signInWithOtp emailRedirectTo).
# Bez tego: fallback na window.location.origin w przeglądarce — preview deploys (PR previews,
# branch deploys) wysyłają magic link na niewłaściwy URL.
NEXT_PUBLIC_APP_URL=https://q2-second-brain-demo.vercel.app

# Service role — TYLKO lokalnie, TYLKO dla seed/admin scripts, NIGDY w kliencie
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Claude API — do Fazy 3+ (AI weekly review)
ANTHROPIC_API_KEY=sk-ant-...
