# Q2 Second Brain — example env vars
# Copy to .env.local and fill in real values to disable demo mode.
# .env.local is gitignored — never commit real credentials.

# ============================================================================
# DEMO MODE (default: true)
# ============================================================================
# When true, the app runs entirely in-browser with localStorage as backend.
# All Supabase variables below are ignored. Reviewers can `pnpm dev` without
# any setup. Set to "false" only when you have a real Supabase project.
NEXT_PUBLIC_DEMO_MODE=true

# ============================================================================
# Supabase (required only if NEXT_PUBLIC_DEMO_MODE=false)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_placeholder

# Service role — server-side only, used by /api/setup-user during onboarding.
# Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_placeholder

# Canonical app URL for magic-link redirects (signInWithOtp emailRedirectTo).
# Without this, preview deploys send the magic link back to the wrong URL.
NEXT_PUBLIC_APP_URL=https://q2-second-brain-demo.vercel.app
