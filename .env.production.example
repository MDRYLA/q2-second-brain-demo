# Production env vars — example (replace with real values, keep gitignored).
# Copy to .env.local for local dev or set in Vercel dashboard for prod.
#
# NEXT_PUBLIC_* trafiają do client JS bundle — są publiczne z definicji.
# RLS w Supabase chroni dane, nie anon key.
# SUPABASE_SERVICE_ROLE_KEY i SUPABASE_DB_PASSWORD trzymaj TYLKO lokalnie.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Faza 7 hardening: NIE wklejaj prefixu eyJhbGci (false-positive dla secret scanners
# typu truffleHog / GitHub Advanced Security — flagują plik jako "JWT token leak").
# Skopiuj prawdziwy publishable key z Supabase Dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Canonical app URL dla magic link emailRedirectTo (Faza 7).
NEXT_PUBLIC_APP_URL=https://q2-second-brain-demo.vercel.app
