    "@scure/bip39": "^2.2.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.47.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^10.3.0",
